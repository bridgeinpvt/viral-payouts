{
  "name": "viral-payouts-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch -r dotenv/config src/index.ts dotenv_config_path=../.env",
    "build": "tsc",
    "start": "node -r dotenv/config dist/index.js dotenv_config_path=../.env",
    "db:generate": "prisma generate --schema=./prisma-worker.prisma",
    "postinstall": "prisma generate --schema=./prisma-worker.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
