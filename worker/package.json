    "razorpay": "^2.9.2",
    "ua-parser-js": "^1.0.37"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/ua-parser-js": "^0.7.39",
    "prisma": "^6.2.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2"
  }
}